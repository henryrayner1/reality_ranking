    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "path": "^0.12.7",
    "react": "^19.1.1",
    "react-avatar-editor": "^15.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.4",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.9.2",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
